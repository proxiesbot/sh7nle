APP_NAME=Sh7nle
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR-DOMAIN.COM

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=HOSTINGER_DATABASE_NAME
DB_USERNAME=HOSTINGER_DATABASE_USER
DB_PASSWORD=HOSTINGER_DATABASE_PASSWORD

BROADCAST_DRIVER=log
CACHE_STORE=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.YOUR-DOMAIN.COM
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=YOUR_EMAIL@YOUR-DOMAIN.COM
MAIL_PASSWORD=YOUR_EMAIL_PASSWORD
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=YOUR_EMAIL@YOUR-DOMAIN.COM
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=YOUR-DOMAIN.COM,www.YOUR-DOMAIN.COM

# Google OAuth - جهزها الآن وفعّلها عند رفع الدومين
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR-DOMAIN.COM/auth/google/callback

# Providers
API_SYRIA_API_KEY=
SW_GAMES_API_TOKEN=
SW_GAMES_BASE_URL=https://sw-games.net/api/fastapi
SAWA_CARD_API_TOKEN=
SHAMS_API_TOKEN=

CREDIT_PRICE=15000
